---
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>批次郵件發送</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f0f2f5;
      color: #222;
      min-height: 100vh;
    }

    header {
      background: #1a73e8;
      color: #fff;
      padding: 16px 32px;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    main {
      max-width: 1400px;
      margin: 32px auto;
      padding: 0 24px;
    }

    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      padding: 28px 32px;
      margin-bottom: 24px;
    }

    .card h2 {
      font-size: 1rem;
      font-weight: 600;
      color: #555;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 20px;
      border-bottom: 2px solid #e8eaed;
      padding-bottom: 10px;
    }

    .upload-zone {
      border: 2px dashed #c1c8d4;
      border-radius: 8px;
      padding: 40px 24px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      background: #fafbfc;
    }
    .upload-zone:hover, .upload-zone.drag-over {
      border-color: #1a73e8;
      background: #e8f0fe;
    }
    .upload-zone .icon { font-size: 2.5rem; margin-bottom: 12px; }
    .upload-zone p { color: #666; font-size: 0.95rem; }
    .upload-zone strong { color: #1a73e8; }
    #file-input { display: none; }

    .config-row {
      display: flex;
      gap: 16px;
      align-items: flex-end;
      flex-wrap: wrap;
    }
    .field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      flex: 1;
      min-width: 220px;
    }
    .field-group label { font-size: 0.85rem; color: #555; font-weight: 500; }
    .field-group input {
      padding: 8px 12px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 0.9rem;
      transition: border-color 0.2s;
    }
    .field-group input:focus { outline: none; border-color: #1a73e8; }

    .btn {
      padding: 9px 20px;
      border: none;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-primary { background: #1a73e8; color: #fff; }
    .btn-primary:hover:not(:disabled) { background: #1557b0; }
    .btn-danger { background: #d93025; color: #fff; }
    .btn-danger:hover:not(:disabled) { background: #b0261e; }
    .btn-outline { background: transparent; color: #1a73e8; border: 1.5px solid #1a73e8; }
    .btn-outline:hover:not(:disabled) { background: #e8f0fe; }
    .btn-sm { padding: 5px 12px; font-size: 0.82rem; }

    .action-bar {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .stats {
      display: flex;
      gap: 20px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .stat {
      background: #f8f9fa;
      border-radius: 8px;
      padding: 12px 20px;
      min-width: 110px;
    }
    .stat .val { font-size: 1.6rem; font-weight: 700; color: #1a73e8; }
    .stat .lbl { font-size: 0.78rem; color: #888; margin-top: 2px; }

    .table-wrap { overflow-x: auto; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
    }
    th {
      background: #f1f3f4;
      padding: 6px 8px;
      text-align: left;
      font-weight: 600;
      color: #444;
      white-space: nowrap;
      height: 32px;
    }
    td {
      padding: 6px 8px;
      border-bottom: 1px solid #f0f0f0;
      vertical-align: middle;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      height: 32px;
    }
    tr:hover td { background: #f8f9ff; }
    
    /* 列寬設定 */
    td:nth-child(1), th:nth-child(1) { width: 24px; }
    td:nth-child(2), th:nth-child(2) { width: 36px; }
    td:nth-child(3), th:nth-child(3) { width: 90px; }
    td:nth-child(4), th:nth-child(4) { width: 100px; }
    td:nth-child(5), th:nth-child(5) { width: 140px; }
    td:nth-child(6), th:nth-child(6) { width: 120px; }
    td:nth-child(7), th:nth-child(7) { width: 100px; }
    td:nth-child(8), th:nth-child(8) { width: 120px; }
    td:nth-child(9), th:nth-child(9) { width: 150px; }
    td:nth-child(10), th:nth-child(10) { width: 80px; }

    .status-badge {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 600;
      white-space: nowrap;
    }
    .badge-success { background: #e6f4ea; color: #137333; }
    .badge-error   { background: #fce8e6; color: #c5221f; }
    .badge-pending { background: #e8f0fe; color: #1967d2; }
    .badge-warning { background: #fef7e0; color: #b45309; }

    tr.row-invalid td { background: #fffbf0; }
    tr.row-invalid:hover td { background: #fef3c7; }

    .error-list { font-size: 0.75rem; color: #b45309; margin-top: 4px; white-space: normal; line-height: 1.5; }

    input[type="checkbox"] { width: 15px; height: 15px; cursor: pointer; accent-color: #1a73e8; }

    #progress-wrap { display: none; margin-top: 16px; }
    .progress-bar-bg {
      background: #e8eaed;
      border-radius: 6px;
      height: 8px;
      overflow: hidden;
    }
    .progress-bar-fill {
      background: #1a73e8;
      height: 100%;
      width: 0%;
      transition: width 0.3s;
    }
    .progress-label { font-size: 0.85rem; color: #555; margin-bottom: 6px; }

    .result-summary {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    #toast {
      position: fixed;
      bottom: 28px;
      right: 28px;
      padding: 12px 20px;
      border-radius: 8px;
      color: #fff;
      font-size: 0.9rem;
      font-weight: 500;
      z-index: 9999;
      transform: translateY(80px);
      opacity: 0;
      transition: all 0.3s;
      max-width: 380px;
    }
    #toast.show { transform: translateY(0); opacity: 1; }
    #toast.success { background: #137333; }
    #toast.error   { background: #c5221f; }
    #toast.info    { background: #1a73e8; }

    .tooltip-cell { cursor: help; position: relative; }
    
    .tooltip {
      position: fixed;
      background: #333;
      color: #fff;
      padding: 8px 12px;
      border-radius: 6px;
      font-size: 0.85rem;
      white-space: normal;
      max-width: 300px;
      word-wrap: break-word;
      z-index: 10000;
      opacity: 1;
      pointer-events: none;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      line-height: 1.4;
      animation: tooltipFadeIn 0.05s ease-out;
    }
    @keyframes tooltipFadeIn { from { opacity: 0; } to { opacity: 1; } }
    .tooltip::after {
      content: '';
      position: absolute;
      bottom: -5px;
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: #333;
    }

    #data-section { display: none; }
  </style>
</head>
<body>
  <header>✉ 批次郵件發送</header>
  <main>

    <div class="card">
      <h2>上傳 Excel</h2>
      <div style="margin-bottom:12px;">
        <a href="http://localhost:8000/api/example" download class="btn btn-outline btn-sm">⬇ 下載範例 Excel</a>
      </div>
      <div class="upload-zone" id="upload-zone">
        <div class="icon">📂</div>
        <p><strong>點擊選擇</strong>或拖曳 Excel 檔案至此</p>
        <p style="margin-top:6px;font-size:0.8rem;color:#999">支援 .xlsx、.xls 格式 &nbsp;|&nbsp; 欄位：Sales / Attn / E-mail / Email CC / Attachment / Email Subject / Email Content</p>
      </div>
      <input type="file" id="file-input" accept=".xlsx,.xls" />
    </div>

    <div class="card" id="attach-card" style="display:none">
      <h2>上傳附件</h2>
      <div id="attach-required" style="margin-bottom:14px;display:flex;flex-wrap:wrap;gap:8px;"></div>
      <div class="upload-zone" id="attach-zone">
        <div class="icon">📎</div>
        <p><strong>點擊選擇</strong>或拖曳附件至此（可多選）</p>
        <p style="margin-top:6px;font-size:0.8rem;color:#999">上傳後檔名需與 Excel Attachment 欄位一致</p>
      </div>
      <input type="file" id="attach-input" multiple />
      <div id="attach-list" style="margin-top:14px;display:flex;flex-wrap:wrap;gap:8px;"></div>
    </div>

    <div class="card">
      <h2>設定</h2>
      <p style="font-size:0.88rem;color:#555;">發測試信時，信件會透過 <strong>Mailpit</strong> 攔截，不會寄出至真實收件人。</p>
      <div style="margin-top:12px;">
        <a href="https://excel-mailpit.automodules.com/" target="_blank" class="btn btn-outline btn-sm">📬 開啟 Mailpit 查看測試信件</a>
      </div>
    </div>

    <div id="data-section">
      <div class="card">
        <h2>資料預覽</h2>
        <div class="stats">
          <div class="stat">
            <div class="val" id="stat-total">0</div>
            <div class="lbl">總筆數</div>
          </div>
          <div class="stat">
            <div class="val" id="stat-selected" style="color:#1a73e8">0</div>
            <div class="lbl">已選取</div>
          </div>
          <div class="stat">
            <div class="val" id="stat-warning" style="color:#b45309">0</div>
            <div class="lbl">有問題</div>
          </div>
          <div class="stat">
            <div class="val" id="stat-success" style="color:#137333">0</div>
            <div class="lbl">已成功</div>
          </div>
          <div class="stat">
            <div class="val" id="stat-error" style="color:#c5221f">0</div>
            <div class="lbl">失敗</div>
          </div>
        </div>

        <div class="action-bar">
          <button class="btn btn-outline btn-sm" id="btn-select-all">全選</button>
          <button class="btn btn-outline btn-sm" id="btn-select-none">取消全選</button>
          <span style="width:1px;height:20px;background:#e0e0e0;display:inline-block;margin:0 4px;"></span>
          <button class="btn btn-outline" id="btn-send-test">🧪 發測試信</button>
          <button class="btn btn-danger" id="btn-send-official">📤 發正式信</button>
          <span id="filename-label" style="font-size:0.85rem;color:#888"></span>
        </div>

        <div id="progress-wrap">
          <div class="progress-label" id="progress-label">準備中...</div>
          <div class="progress-bar-bg">
            <div class="progress-bar-fill" id="progress-bar"></div>
          </div>
          <div class="result-summary" id="result-summary"></div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th><input type="checkbox" id="check-all" title="全選/取消全選" /></th>
                <th>#</th>
                <th>Sales</th>
                <th>Attn</th>
                <th>E-mail</th>
                <th>Email CC</th>
                <th>Attachment</th>
                <th>Email Subject</th>
                <th>Email Content</th>
                <th>狀態</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
      </div>
    </div>

  </main>
  <div id="toast"></div>

  <script>
    const API = import.meta.env.PUBLIC_API_URL || '';
    let sessionId = null;
    let rows = [];
    let rowStatuses = [];
    let rowErrors = [];
    let rowChecked = [];
    let requiredAttachments = new Set();  // filenames needed by current Excel
    let uploadedAttachments = new Set();  // filenames already uploaded this session

    // Attachments upload
    const attachZone = document.getElementById('attach-zone');
    const attachInput = document.getElementById('attach-input');

    attachZone.addEventListener('click', () => attachInput.click());
    attachZone.addEventListener('dragover', e => { e.preventDefault(); attachZone.classList.add('drag-over'); });
    attachZone.addEventListener('dragleave', () => attachZone.classList.remove('drag-over'));
    attachZone.addEventListener('drop', e => {
      e.preventDefault();
      attachZone.classList.remove('drag-over');
      if (e.dataTransfer.files.length) handleAttachUpload(e.dataTransfer.files);
    });
    attachInput.addEventListener('change', () => {
      if (attachInput.files.length) handleAttachUpload(attachInput.files);
      attachInput.value = '';
    });

    async function handleAttachUpload(files) {
      if (!sessionId) { toast('請先上傳 Excel', 'error'); return; }
      const fd = new FormData();
      for (const f of files) fd.append('files', f);
      try {
        const res = await fetch(`${API}/api/attachments/${sessionId}`, { method: 'POST', body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.detail || '上傳失敗');
        data.saved.forEach(f => uploadedAttachments.add(f));
        renderAttachStatus();
        
        // Update row checked status - auto-check rows that now have all attachments
        rows.forEach((r, i) => {
          const attachmentNeeded = (r['Attachment'] || '').trim();
          // If this row needs an attachment and it's now uploaded, auto-check it (if no other errors)
          if (attachmentNeeded && uploadedAttachments.has(attachmentNeeded) && rowErrors[i].length === 0) {
            rowChecked[i] = true;
          }
        });
        renderTable();
        updateStats();
        
        toast('已上傳 ' + data.saved.length + ' 個附件', 'success');
      } catch (err) {
        toast('附件上傳失敗: ' + err.message, 'error');
      }
    }

    function renderAttachStatus() {
      const required = document.getElementById('attach-required');
      const list = document.getElementById('attach-list');
      if (!requiredAttachments.size) {
        required.innerHTML = '<span style="font-size:0.85rem;color:#888;">本次 Excel 無需附件</span>';
        list.innerHTML = '';
        return;
      }
      required.innerHTML = [...requiredAttachments].map(f => {
        const ok = uploadedAttachments.has(f);
        return `<span style="background:${ok ? '#e6f4ea' : '#fce8e6'};border-radius:6px;padding:4px 10px;font-size:0.82rem;color:${ok ? '#137333' : '#c5221f'};">${ok ? '✓' : '✗'} ${esc(f)}</span>`;
      }).join('');
      list.innerHTML = '';
    }

    // Upload
    const uploadZone = document.getElementById('upload-zone');
    const fileInput = document.getElementById('file-input');

    uploadZone.addEventListener('click', () => fileInput.click());
    uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
    uploadZone.addEventListener('drop', e => {
      e.preventDefault();
      uploadZone.classList.remove('drag-over');
      if (e.dataTransfer.files[0]) handleUpload(e.dataTransfer.files[0]);
    });
    fileInput.addEventListener('change', () => {
      if (fileInput.files[0]) handleUpload(fileInput.files[0]);
    });

    async function handleUpload(file) {
      const fd = new FormData();
      fd.append('file', file);
      uploadZone.innerHTML = '<div class="icon">⏳</div><p>上傳中...</p>';
      try {
        const res = await fetch(`${API}/api/upload`, { method: 'POST', body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.detail || '上傳失敗');

        sessionId = data.session_id;
        rows = data.rows;
        rowErrors = data.row_errors || rows.map(() => []);
        rowStatuses = rows.map(() => 'pending');
        
        // Reset attachment tracking for new session
        uploadedAttachments = new Set();
        requiredAttachments = new Set(
          rows.map(r => (r['Attachment'] || '').trim()).filter(Boolean)
        );
        
        // Only auto-check rows without errors AND without required attachments
        rowChecked = rows.map((r, i) => {
          if (rowErrors[i].length > 0) return false;  // Has validation errors
          const attachmentNeeded = (r['Attachment'] || '').trim();
          if (attachmentNeeded) return false;  // Has attachment requirement but not uploaded yet
          return true;  // No errors and no attachment needed
        });
        document.getElementById('attach-card').style.display = 'block';
        renderAttachStatus();

        const invalidCount = rowErrors.filter(e => e.length > 0).length;
        document.getElementById('filename-label').textContent = '📄 ' + data.filename;
        renderTable();
        document.getElementById('data-section').style.display = 'block';
        document.getElementById('progress-wrap').style.display = 'none';
        document.getElementById('result-summary').innerHTML = '';
        updateStats();
        if (invalidCount > 0) {
          toast(`載入 ${rows.length} 筆，其中 ${invalidCount} 筆有問題（已預設取消選取）`, 'error');
        } else {
          toast('成功載入 ' + rows.length + ' 筆資料', 'success');
        }
        uploadZone.innerHTML = '<div class="icon">✅</div><p><strong>已載入：</strong>' + esc(file.name) + '</p><p style="margin-top:6px;font-size:0.8rem;color:#999">點擊重新上傳</p>';
      } catch (err) {
        toast(err.message, 'error');
        uploadZone.innerHTML = '<div class="icon">📂</div><p><strong>點擊選擇</strong>或拖曳 Excel 檔案至此</p><p style="margin-top:6px;font-size:0.8rem;color:#999">支援 .xlsx、.xls 格式</p>';
      }
      fileInput.value = '';
    }

    function renderTable() {
      const tbody = document.getElementById('table-body');
      tbody.innerHTML = rows.map((r, i) => {
        const errs = rowErrors[i] || [];
        const hasErr = errs.length > 0;
        const checked = rowChecked[i] ? 'checked' : '';
        const rowClass = hasErr ? 'row-invalid' : '';
        const statusText = hasErr ? '⚠ 有問題' : '待發送';
        const statusClass = hasErr ? 'badge-warning' : 'badge-pending';
        const errorsDisplay = hasErr ? (`錯誤：${errs.join('; ')}`) : '';
        
        // 文本截斷函數
        const truncate = (text, len = 30) => {
          text = esc(text);
          return text.length > len ? text.substring(0, len) + '…' : text;
        };
        
        const attachmentText = truncate(r['Attachment'] || '', 15);
        const subjectText = truncate(r['Email Subject'] || '', 30);
        const contentText = truncate(r['Email Content'] || '', 40);
        
        return `
        <tr id="row-${i}" class="${rowClass}">
          <td><input type="checkbox" class="row-check" data-idx="${i}" ${checked} /></td>
          <td>${i + 1}</td>
          <td class="tooltip-cell" title="${esc(r['Sales'])}">${esc(r['Sales'])}</td>
          <td class="tooltip-cell" title="${esc(r['Attn'])}">${esc(r['Attn'])}</td>
          <td class="tooltip-cell" title="${esc(r['E-mail'])}">${esc(r['E-mail'])}</td>
          <td class="tooltip-cell" title="${esc(r['Email CC'])}">${esc(r['Email CC'])}</td>
          <td class="tooltip-cell" title="${esc(r['Attachment'] || '')}">${attachmentText}</td>
          <td class="tooltip-cell" title="${esc(r['Email Subject'])}">${subjectText}</td>
          <td class="tooltip-cell" title="${esc(r['Email Content'])}">${contentText}</td>
          <td id="status-${i}" class="tooltip-cell" title="${errorsDisplay}">
            <span class="status-badge ${statusClass}">${statusText}</span>
          </td>
        </tr>`;
      }).join('');
      document.getElementById('check-all').checked = rowChecked.every(Boolean);
      initTooltips();
    }

    function updateRowStatus(i, status, msg) {
      rowStatuses[i] = status;
      const cell = document.getElementById('status-' + i);
      if (!cell) return;
      if (status === 'success') {
        cell.innerHTML = '<span class="status-badge badge-success">✓ 成功</span>';
        cell.setAttribute('title', '');
      } else if (status === 'error') {
        cell.innerHTML = '<span class="status-badge badge-error">✗ 失敗</span>';
        cell.setAttribute('title', msg || '');
      } else {
        cell.innerHTML = '<span class="status-badge badge-pending">⏳ 發送中</span>';
        cell.setAttribute('title', '');
      }
      updateStats();
    }

    function initTooltips() {
      let activeTooltip = null;
      let hideTimeout = null;
      
      document.querySelectorAll('.tooltip-cell').forEach(el => {
        // 禁用浏览器默认 title tooltip
        el.addEventListener('mouseenter', (e) => {
          clearTimeout(hideTimeout);
          
          const tooltip_text = el.getAttribute('title');
          if (!tooltip_text) return;
          
          if (activeTooltip) activeTooltip.remove();
          
          const tooltip = document.createElement('div');
          tooltip.className = 'tooltip';
          tooltip.textContent = tooltip_text;
          document.body.appendChild(tooltip);
          
          const rect = el.getBoundingClientRect();
          tooltip.style.left = (rect.left + rect.width / 2 - 150) + 'px';
          tooltip.style.top = (rect.top - 45) + 'px';
          
          activeTooltip = tooltip;
          
          // 阻止浏览器默认 tooltip
          e.preventDefault();
        }, true);

        el.addEventListener('mouseleave', () => {
          hideTimeout = setTimeout(() => {
            if (activeTooltip) {
              activeTooltip.remove();
              activeTooltip = null;
            }
          }, 50);
        });
      });
    }

    function updateStats() {
      document.getElementById('stat-total').textContent = rows.length;
      document.getElementById('stat-selected').textContent = rowChecked.filter(Boolean).length;
      document.getElementById('stat-warning').textContent = rowErrors.filter(e => e.length > 0).length;
      document.getElementById('stat-success').textContent = rowStatuses.filter(s => s === 'success').length;
      document.getElementById('stat-error').textContent = rowStatuses.filter(s => s === 'error').length;
    }

    async function sendOne(idx, type) {
      if (!sessionId) return;
      const att = (rows[idx]['Attachment'] || '').trim();
      if (att && !uploadedAttachments.has(att)) {
        toast(`請先上傳附件：${att}`, 'error');
        return;
      }
      updateRowStatus(idx, 'sending');
      try {
        const res = await fetch(`${API}/api/send`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ session_id: sessionId, row_index: idx, send_type: type })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.detail || '發送失敗');
        updateRowStatus(idx, 'success');
        toast('第 ' + (idx+1) + ' 筆' + (type==='test'?'測試':'') + '信件已發送', 'success');
      } catch (err) {
        updateRowStatus(idx, 'error', err.message);
        toast('第 ' + (idx+1) + ' 筆失敗: ' + err.message, 'error');
      }
    }

    async function sendAll(type) {
      if (!sessionId || !rows.length) return;
      const selected = rows.reduce((acc, _, i) => rowChecked[i] ? [...acc, i] : acc, []);
      if (!selected.length) { toast('請先選取至少一列', 'error'); return; }

      // Pre-flight: check all required attachments for selected rows are uploaded
      const missing = new Set(
        selected.map(i => (rows[i]['Attachment'] || '').trim())
                .filter(f => f && !uploadedAttachments.has(f))
      );
      if (missing.size > 0) {
        toast('發送前請先上傳附件：' + [...missing].join('、'), 'error');
        return;
      }

      if (type === 'official') {
        if (!confirm(`確定要發送正式信件給已選取的 ${selected.length} 位收件人嗎？此操作無法復原。`)) return;
      }

      document.getElementById('btn-send-test').disabled = true;
      document.getElementById('btn-send-official').disabled = true;
      const progressWrap = document.getElementById('progress-wrap');
      progressWrap.style.display = 'block';
      document.getElementById('result-summary').innerHTML = '';

      let success = 0, error = 0;
      for (let n = 0; n < selected.length; n++) {
        const i = selected[n];
        document.getElementById('progress-label').textContent = '發送中 ' + (n+1) + ' / ' + selected.length;
        document.getElementById('progress-bar').style.width = ((n+1)/selected.length*100).toFixed(0) + '%';
        updateRowStatus(i, 'sending');

        try {
          const res = await fetch(`${API}/api/send`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ session_id: sessionId, row_index: i, send_type: type })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.detail || '失敗');
          updateRowStatus(i, 'success');
          success++;
        } catch (err) {
          updateRowStatus(i, 'error', err.message);
          error++;
        }
      }

      document.getElementById('progress-label').textContent = '完成！成功 ' + success + ' 筆，失敗 ' + error + ' 筆';
      document.getElementById('result-summary').innerHTML =
        '<span class="status-badge badge-success">✓ 成功 ' + success + '</span>' +
        (error ? ' &nbsp; <span class="status-badge badge-error">✗ 失敗 ' + error + '</span>' : '');

      document.getElementById('btn-send-test').disabled = false;
      document.getElementById('btn-send-official').disabled = false;
      toast((type==='test'?'測試':'正式') + '信件完成：成功 ' + success + '，失敗 ' + error, error ? 'error' : 'success');
    }

    document.getElementById('btn-send-test').addEventListener('click', () => sendAll('test'));
    document.getElementById('btn-send-official').addEventListener('click', () => sendAll('official'));

    document.getElementById('btn-select-all').addEventListener('click', () => {
      rowChecked = rowChecked.map(() => true);
      document.querySelectorAll('.row-check').forEach(cb => cb.checked = true);
      document.getElementById('check-all').checked = true;
      updateStats();
    });

    document.getElementById('btn-select-none').addEventListener('click', () => {
      rowChecked = rowChecked.map(() => false);
      document.querySelectorAll('.row-check').forEach(cb => cb.checked = false);
      document.getElementById('check-all').checked = false;
      updateStats();
    });

    document.getElementById('check-all').addEventListener('change', e => {
      rowChecked = rowChecked.map(() => e.target.checked);
      document.querySelectorAll('.row-check').forEach(cb => cb.checked = e.target.checked);
      updateStats();
    });

    document.getElementById('table-body').addEventListener('change', e => {
      const cb = e.target.closest('.row-check');
      if (!cb) return;
      rowChecked[parseInt(cb.dataset.idx)] = cb.checked;
      document.getElementById('check-all').checked = rowChecked.every(Boolean);
      updateStats();
    });



    let toastTimer;
    function toast(msg, type) {
      type = type || 'info';
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.className = 'show ' + type;
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => { el.className = ''; }, 4000);
    }

    function esc(str) {
      return String(str == null ? '' : str)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // Clean up current session when leaving the page
    function deleteCurrentSession() {
      if (!sessionId) return;
      fetch(`${API}/api/sessions/${sessionId}`, { method: 'DELETE', keepalive: true });
      sessionId = null;
    }
    window.addEventListener('pagehide', deleteCurrentSession);

</script>
</body>
</html>
